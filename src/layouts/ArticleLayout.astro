---
import Layout from './Layout.astro';
import MetadataRail from '../components/MetadataRail.astro';
import ThesisBlock from '../components/ThesisBlock.astro';
import { formatDate } from '../lib/format';

interface RelatedLink {
	href: string;
	title: string;
}

interface Props {
	title: string;
	subtitle?: string;
	type: 'Essay' | 'Note';
	status: string;
	field?: string;
	topics?: string[];
	published: Date;
	updated?: Date;
	thesis?: string;
	claim?: string;
	series?: { slug: string; title: string };
	related?: RelatedLink[];
	description?: string;
	canonical?: string;
}

const {
	title,
	subtitle,
	type,
	status,
	field,
	topics,
	published,
	updated,
	thesis,
	claim,
	series,
	related = [],
	description,
	canonical,
} = Astro.props;

const meta = description ?? subtitle ?? thesis ?? claim ?? title;
---

<Layout
	title={title}
	description={meta}
	type="article"
	published={published}
	updated={updated}
	canonical={canonical}
>
	<article class="container article">
		<MetadataRail
			type={type}
			status={status}
			field={field}
			topics={topics}
			published={published}
			updated={updated}
			series={series}
		/>

		<div>
			<header>
				<h1>{title}</h1>
				{subtitle && <p class="subtitle">{subtitle}</p>}
				{thesis && <ThesisBlock text={thesis} variant="thesis" />}
				{claim && !thesis && <ThesisBlock text={claim} variant="claim" />}
			</header>

			<div class="prose">
				<slot />
			</div>

			<footer class="trail">
				<div>
					<span>First published: {formatDate(published)}</span>
					{updated && <span> · Last updated: {formatDate(updated)}</span>}
				</div>
				{related.length > 0 && (
					<div class="trail-group">
						<span class="label">Continues</span>
						<ul>
							{related.map((r) => (
								<li>
									<a href={r.href}>{r.title}</a>
								</li>
							))}
						</ul>
					</div>
				)}
				{series && (
					<div class="trail-group">
						<span class="label">Series</span>
						<ul>
							<li>
								<a href={`/series/${series.slug}`}>{series.title}</a>
							</li>
						</ul>
					</div>
				)}
			</footer>
		</div>
	</article>
</Layout>
