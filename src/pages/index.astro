---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ArchiveList from '../components/ArchiveList.astro';
import { formatDate } from '../lib/format';

const essays = (await getCollection('essays', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);
const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);
const allSeries = (await getCollection('series')).sort(
	(a, b) => b.data.started.getTime() - a.data.started.getTime(),
);

const currentEssay = essays[0];
const ongoingSeries =
	allSeries.find((s) => s.id === 'the-great-arch-of-digitalization') ??
	allSeries.find((s) => s.data.status === 'Active') ??
	allSeries[0];

type Combined = {
	href: string;
	title: string;
	date: Date;
	gloss: string;
	type: 'Essay' | 'Note';
	field: string | undefined;
};

const combined: Combined[] = [
	...essays.map((e) => ({
		href: `/essays/${e.id}`,
		title: e.data.title,
		date: e.data.published,
		gloss: e.data.thesis,
		type: 'Essay' as const,
		field: e.data.field ?? e.data.topics[0],
	})),
	...notes.map((n) => ({
		href: `/notes/${n.id}`,
		title: n.data.title,
		date: n.data.published,
		gloss: n.data.claim,
		type: 'Note' as const,
		field: n.data.field ?? n.data.topics[0],
	})),
]
	.sort((a, b) => b.date.getTime() - a.date.getTime())
	.slice(0, 8);

const latestEntries = combined.map((c) => ({
	href: c.href,
	title: c.title,
	date: c.date,
	gloss: c.gloss,
	tags: [c.type, c.field].filter(Boolean) as string[],
}));

const SITE_URL = 'https://digsdeeper.com';
const SITE_DESCRIPTION =
	'Serious essays about software, strategy, AI, systems, and technology culture. Long-form arguments, working notes, and investigations by Jean Lucas Lima.';

const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		'@id': `${SITE_URL}/#website`,
		url: SITE_URL,
		name: 'digsdeeper',
		description: SITE_DESCRIPTION,
		inLanguage: 'en',
		publisher: { '@id': `${SITE_URL}/#person` },
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		'@id': `${SITE_URL}/#person`,
		name: 'Jean Lucas Lima',
		url: 'https://jeanlucas.me',
		sameAs: [
			'https://github.com/jeanlucaslima',
			'https://aleattorium.com',
			'https://l8p.tech',
		],
	},
];
---

<Layout jsonLd={jsonLd}>
	<section class="container hero hero-compact">
		<h1 class="hero-tagline">Serious essays about software, strategy, AI, systems, and technology culture.</h1>
		<p class="hero-byline">
			Long-form arguments, working notes, and investigations by
			<a href="https://jeanlucas.me">Jean Lucas Lima</a>.
		</p>
	</section>

	<section class="container featured-row" aria-label="Current writing">
		{
			currentEssay && (
				<article class="featured-block">
					<span class="featured-label">Current essay</span>
					<h2 class="featured-title">
						<a href={`/essays/${currentEssay.id}`}>{currentEssay.data.title}</a>
					</h2>
					<p class="featured-thesis">{currentEssay.data.thesis}</p>
					<p class="featured-meta">
						<span>Essay</span>
						<span>{formatDate(currentEssay.data.published)}</span>
						{currentEssay.data.field && <span>{currentEssay.data.field}</span>}
					</p>
				</article>
			)
		}
		{
			ongoingSeries && (
				<article class="featured-block">
					<span class="featured-label">Ongoing investigation</span>
					<h2 class="featured-title">
						<a href={`/series/${ongoingSeries.id}`}>{ongoingSeries.data.title}</a>
					</h2>
					<p class="featured-thesis">{ongoingSeries.data.central_question}</p>
					<p class="featured-meta">
						<span>Series</span>
						<span>{ongoingSeries.data.status}</span>
					</p>
				</article>
			)
		}
	</section>

	<section class="container section">
		<div class="section-head">
			<h2>Latest writing</h2>
			<a href="/essays">All essays →</a>
		</div>
		{
			latestEntries.length > 0 ? (
				<ArchiveList entries={latestEntries} />
			) : (
				<p class="muted">No writing yet.</p>
			)
		}
	</section>

	<section class="container section">
		<div class="section-head">
			<h2>Series</h2>
			<a href="/series">All series →</a>
		</div>
		<ul class="series-list">
			{
				allSeries.map((s) => (
					<li>
						<p class="name">
							<a href={`/series/${s.id}`}>{s.data.title}</a>
						</p>
						<p class="q">{s.data.central_question}</p>
						<div class="row2">{s.data.status}</div>
					</li>
				))
			}
		</ul>
	</section>
</Layout>
