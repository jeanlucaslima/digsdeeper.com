---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArchiveList from '../../components/ArchiveList.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const entries = notes.map((n) => ({
	href: `/notes/${n.id}`,
	title: n.data.title,
	date: n.data.published,
	gloss: n.data.claim,
	tags: ['Note', n.data.status, n.data.field ?? n.data.topics[0]].filter(Boolean) as string[],
}));
---

<Layout title="Notes" description="Working observations and shorter research notes by Jean Lucas Lima.">
	<section class="container">
		<header class="page-head">
			<span class="eyebrow">Archive · Notes</span>
			<h1>Notes</h1>
			<p class="gloss">Shorter observations and partial arguments. Each note carries a claim or question, even when it isn't yet an essay.</p>
		</header>
		{entries.length > 0 ? <ArchiveList entries={entries} /> : <p class="muted">No notes yet.</p>}
	</section>
</Layout>
