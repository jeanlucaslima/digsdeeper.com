---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArchiveList from '../../components/ArchiveList.astro';
import ThesisBlock from '../../components/ThesisBlock.astro';
import { formatDate } from '../../lib/format';

export async function getStaticPaths() {
	const allSeries = await getCollection('series');
	return allSeries.map((s) => ({ params: { slug: s.id }, props: { entry: s } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const essays = (await getCollection('essays', ({ data }) => !data.draft && data.series === entry.id)).sort(
	(a, b) => a.data.published.getTime() - b.data.published.getTime(),
);

const entries = essays.map((e) => ({
	href: `/essays/${e.id}`,
	title: e.data.title,
	date: e.data.published,
	gloss: e.data.thesis,
	tags: ['Essay', e.data.status].filter(Boolean) as string[],
}));
---

<Layout
	title={entry.data.title}
	description={entry.data.description ?? entry.data.central_question}
>
	<section class="container">
		<header class="page-head">
			<span class="eyebrow">Series · {entry.data.status}</span>
			<h1>{entry.data.title}</h1>
		</header>

		<ThesisBlock label="Central question" text={entry.data.central_question} variant="thesis" />

		<p class="meta-row">
			<span>Started {formatDate(entry.data.started)}</span>
			{entry.data.updated && <span>Updated {formatDate(entry.data.updated)}</span>}
		</p>

		<div class="prose measure">
			<Content />
		</div>

		{
			entry.data.reading_path.length > 0 && (
				<div class="reading-path measure">
					<span class="eyebrow">Reading path</span>
					<ol>
						{entry.data.reading_path.map((t) => (
							<li>{t}</li>
						))}
					</ol>
				</div>
			)
		}

		<div class="section-head section-head-spaced">
			<h2>Entries</h2>
		</div>
		{entries.length > 0 ? <ArchiveList entries={entries} /> : <p class="muted">No entries yet.</p>}
	</section>
</Layout>
