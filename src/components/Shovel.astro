---
interface Props {
	size?: number;
	title?: string;
	class?: string;
}

const { size = 18, title, class: className } = Astro.props;
const role = title ? 'img' : undefined;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 10 12"
	width={size}
	height={Math.round((size * 12) / 10)}
	fill="currentColor"
	shape-rendering="crispEdges"
	role={role}
	aria-hidden={title ? undefined : 'true'}
	class={className}
>
	{title && <title>{title}</title>}
	<!-- D-grip -->
	<rect x="3" y="0" width="4" height="1" />
	<rect x="3" y="1" width="1" height="1" />
	<rect x="6" y="1" width="1" height="1" />
	<rect x="3" y="2" width="4" height="1" />
	<!-- shaft -->
	<rect x="4" y="3" width="2" height="4" />
	<!-- blade -->
	<rect x="3" y="7" width="4" height="1" />
	<rect x="2" y="8" width="6" height="1" />
	<rect x="1" y="9" width="8" height="2" />
	<rect x="2" y="11" width="6" height="1" />
</svg>
