---
interface Props {
	size?: number;
	title?: string;
	class?: string;
}

const { size = 22, title, class: className } = Astro.props;
const role = title ? 'img' : undefined;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 24 24"
	width={size}
	height={size}
	role={role}
	aria-hidden={title ? undefined : 'true'}
	class={className}
>
	{title && <title>{title}</title>}
	<!-- Triangular caution sign body -->
	<path
		d="M12 2.5 L22.5 21 H1.5 Z"
		fill="#d8b758"
		stroke="#171411"
		stroke-width="1.8"
		stroke-linejoin="round"
	/>
	<!-- Shovel grip -->
	<rect x="10.5" y="10" width="3" height="1.4" fill="#171411" />
	<!-- Shovel shaft -->
	<rect x="11.4" y="11.4" width="1.2" height="4" fill="#171411" />
	<!-- Shovel blade -->
	<polygon points="8.6,15.4 15.4,15.4 14.2,19 9.8,19" fill="#171411" />
</svg>
