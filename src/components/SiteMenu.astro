---
import Shovel from './Shovel.astro';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

interface Link {
	href: string;
	label: string;
	gloss?: string;
	match: RegExp;
}

const writing: Link[] = [
	{ href: '/', label: 'Front page', gloss: 'Latest writing and current arguments', match: /^\/$/ },
	{ href: '/essays', label: 'Essays', gloss: 'Long-form arguments', match: /^\/essays/ },
	{ href: '/notes', label: 'Notes', gloss: 'Working thoughts and partial arguments', match: /^\/notes/ },
	{ href: '/series', label: 'Series', gloss: 'Ongoing investigations', match: /^\/series/ },
	{ href: '/about', label: 'About', gloss: 'What this site is', match: /^\/about/ },
];

const subscribe: Link[] = [
	{ href: '/feed.xml', label: 'RSS feed', gloss: 'Essays and notes as they are published', match: /^\/feed\.xml$/ },
	{ href: '/llms.txt', label: 'llms.txt', gloss: 'Machine-readable map for search and AI', match: /^\/llms\.txt$/ },
];

const elsewhere = [
	{ href: 'https://jeanlucas.me', label: 'jeanlucas.me', gloss: 'Canonical identity' },
	{ href: 'https://aleattorium.com', label: 'aleattorium.com', gloss: 'Studio for useful oddities' },
	{ href: 'https://l8p.tech', label: 'L8P', gloss: 'Tech media and events' },
];

function isCurrent(match: RegExp): boolean {
	return match.test(pathname);
}
---

<div
	id="site-menu"
	class="site-menu"
	data-open="false"
	aria-hidden="true"
	aria-labelledby="site-menu-heading"
	inert
>
	<div class="container site-menu-inner">
		<div class="site-menu-head">
			<span class="site-menu-mark">
				<Shovel size={26} class="site-menu-shovel" />
				<span class="eyebrow" id="site-menu-heading">Contents</span>
			</span>
			<button class="menu-trigger" type="button" data-menu-close aria-label="Close menu">CLOSE</button>
		</div>

		<nav class="site-menu-body" aria-label="Contents">
			<section class="menu-group">
				<h2 class="menu-group-label">Writing</h2>
				<ul>
					{
						writing.map((l) => (
							<li>
								<a
									href={l.href}
									data-menu-link
									aria-current={isCurrent(l.match) ? 'page' : undefined}
								>
									<span class="menu-link-label">{l.label}</span>
									{l.gloss && <span class="menu-link-gloss">{l.gloss}</span>}
									{isCurrent(l.match) && <span class="menu-current">Current</span>}
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="menu-group">
				<h2 class="menu-group-label">Subscribe</h2>
				<ul>
					{
						subscribe.map((l) => (
							<li>
								<a
									href={l.href}
									data-menu-link
									aria-current={isCurrent(l.match) ? 'page' : undefined}
								>
									<span class="menu-link-label">{l.label}</span>
									{l.gloss && <span class="menu-link-gloss">{l.gloss}</span>}
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="menu-group">
				<h2 class="menu-group-label">Elsewhere</h2>
				<ul>
					{
						elsewhere.map((l) => (
							<li>
								<a href={l.href} rel="me noopener" data-menu-link>
									<span class="menu-link-label">{l.label}</span>
									{l.gloss && <span class="menu-link-gloss">{l.gloss}</span>}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</nav>
	</div>
</div>

<script>
	const menu = document.getElementById('site-menu');
	const triggers = document.querySelectorAll<HTMLButtonElement>('[data-menu-trigger]');
	const closers = document.querySelectorAll<HTMLButtonElement>('[data-menu-close]');
	let lastFocus: HTMLElement | null = null;

	function isOpen() {
		return menu?.getAttribute('data-open') === 'true';
	}

	function openMenu() {
		if (!menu) return;
		lastFocus = document.activeElement as HTMLElement | null;
		menu.setAttribute('data-open', 'true');
		menu.setAttribute('aria-hidden', 'false');
		menu.removeAttribute('inert');
		document.documentElement.classList.add('menu-open');
		document.body.style.overflow = 'hidden';
		triggers.forEach((t) => {
			t.setAttribute('aria-expanded', 'true');
			t.textContent = 'CLOSE';
		});
		const firstLink = menu.querySelector<HTMLAnchorElement>('a[data-menu-link]');
		firstLink?.focus();
	}

	function closeMenu() {
		if (!menu) return;
		menu.setAttribute('data-open', 'false');
		menu.setAttribute('aria-hidden', 'true');
		menu.setAttribute('inert', '');
		document.documentElement.classList.remove('menu-open');
		document.body.style.overflow = '';
		triggers.forEach((t) => {
			t.setAttribute('aria-expanded', 'false');
			t.textContent = 'MENU';
		});
		lastFocus?.focus();
	}

	function toggle() {
		if (!menu) return;
		if (isOpen()) closeMenu();
		else openMenu();
	}

	triggers.forEach((t) => t.addEventListener('click', toggle));
	closers.forEach((c) => c.addEventListener('click', closeMenu));

	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && isOpen()) {
			e.preventDefault();
			closeMenu();
		}
	});

	menu?.querySelectorAll<HTMLAnchorElement>('a[data-menu-link]').forEach((a) => {
		a.addEventListener('click', () => {
			closeMenu();
		});
	});
</script>
