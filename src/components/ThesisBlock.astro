---
interface Props {
	label?: string;
	text: string;
	variant?: 'thesis' | 'claim';
}
const { label, text, variant = 'thesis' } = Astro.props;
const defaultLabel = variant === 'claim' ? 'Claim' : 'Thesis';
---

<div class={variant}>
	<span class="label">{label ?? defaultLabel}</span>
	<p style="margin:0">{text}</p>
</div>
